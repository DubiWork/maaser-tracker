rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if user is accessing their own data
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Default: Deny all access unless explicitly granted
    match /{document=**} {
      allow read, write: if false;
    }

    // User-specific entries collection
    // Path: /users/{userId}/entries/{entryId}
    match /users/{userId}/entries/{entryId} {
      // Users can read their own entries
      allow read: if isOwner(userId);

      // Users can create entries in their own collection
      // Validate that userId in document matches authenticated user
      allow create: if isOwner(userId)
                    && request.resource.data.userId == request.auth.uid;

      // Users can update their own entries
      // Prevent changing userId field
      allow update: if isOwner(userId)
                    && request.resource.data.userId == resource.data.userId;

      // Users can delete their own entries
      allow delete: if isOwner(userId);
    }

    // User profile/settings collection
    // Path: /users/{userId}
    match /users/{userId} {
      // Users can read their own profile
      allow read: if isOwner(userId);

      // Users can create their own profile
      allow create: if isOwner(userId);

      // Users can update their own profile
      // Prevent changing uid field
      allow update: if isOwner(userId)
                    && request.resource.data.uid == resource.data.uid;

      // Users can delete their own profile (for account deletion)
      allow delete: if isOwner(userId);
    }

    // Migration metadata document
    // Path: /users/{userId}/metadata/migration
    match /users/{userId}/metadata/migration {
      // Users can read their own migration status
      allow read: if isOwner(userId);

      // Users can create migration status if it doesn't exist
      // Must include consent fields for GDPR compliance
      allow create: if isOwner(userId)
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.consentGivenAt != null
                    && request.resource.data.consentVersion != null;

      // Users can update migration status only if not already completed
      // This prevents duplicate migrations and tampering with completed records
      // SECURITY FIX: Removed the cancelled override that allowed overwriting completed migrations
      allow update: if isOwner(userId)
                    && request.resource.data.userId == request.auth.uid
                    && !resource.data.completed;

      // Users can delete migration status (required for GDPR Article 17 erasure)
      allow delete: if isOwner(userId);
    }

    // Migration history subcollection
    // Path: /users/{userId}/metadata/migration/history/{eventId}
    match /users/{userId}/metadata/migration/history/{eventId} {
      // Users can read their own migration history
      allow read: if isOwner(userId);

      // Users can create history entries
      allow create: if isOwner(userId)
                    && request.resource.data.userId == request.auth.uid;

      // History entries are immutable (audit trail)
      allow update: if false;
      // Users can delete their own history entries (required for GDPR Article 17 erasure)
      allow delete: if isOwner(userId);
    }
  }
}
